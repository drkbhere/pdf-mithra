#!/bin/bash
SCRIPT="$(cd "$(dirname "$0")" && pwd)"
PROJECT="$(dirname "$(dirname "$(dirname "$SCRIPT")")")"

cd "$PROJECT"

PYTHON="$PROJECT/venv/bin/python3"
if [ ! -f "$PYTHON" ]; then
    PYTHON="$(which python3)"
fi

# On Apple Silicon, macOS may launch a universal Python in x86_64 mode via double-click.
# Force the native architecture to match the venv's compiled packages.
ARCH="$(uname -m)"
if [ "$ARCH" = "arm64" ]; then
    exec arch -arm64 "$PYTHON" "$PROJECT/src/app.py"
else
    exec "$PYTHON" "$PROJECT/src/app.py"
fi
