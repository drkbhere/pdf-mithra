#!/bin/bash
SCRIPT="$(cd "$(dirname "$0")" && pwd)"
PROJECT="$(dirname "$(dirname "$(dirname "$SCRIPT")")")"

cd "$PROJECT"

PYTHON="$PROJECT/venv/bin/python3"
if [ ! -f "$PYTHON" ]; then
    PYTHON="$(which python3)"
fi

# Force arm64 — Python is a universal binary and macOS may pick x86_64 on double-click
exec arch -arm64 "$PYTHON" "$PROJECT/src/app.py"
